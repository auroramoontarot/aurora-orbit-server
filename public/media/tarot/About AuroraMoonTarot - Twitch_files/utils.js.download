// ============================================================================
// DATA MERGING
// ============================================================================

function mergeWithOverrides(serverList, overrideList, twitchProducts = null) {
    const serverMap = new Map(
        serverList.map(item => [item.displayName, item])
    );

    const usedNames = new Set();
    const merged = overrideList.map(override => {
        const serverItem = serverMap.get(override.displayName);
        usedNames.add(override.displayName);

        // If item no longer exists on server (custom or removed), keep it
        if (!serverItem) {
            return { ...override };
        }

        // Merge: server defaults ← overridden by saved config
        return {
            ...serverItem,
            ...override
        };
    });

    // 2️⃣ Append new server items not in saved config
    serverList.forEach(serverItem => {
        if (!usedNames.has(serverItem.displayName)) {
            merged.push({ ...serverItem });
        }
    });

    // 3️⃣ Optional: filter invalid SKUs
    if (twitchProducts) {
        return merged.filter(item =>
            twitchProducts.some(p => p.sku === item.sku)
        );
    }

    return merged;
}

function isDuplicateName({ name, type }) {
    name = name.trim().toLowerCase();
    if (type === 'item') {
        return catalog.some(
            item => item.displayName.trim().toLowerCase() === name
        );
    } else if (type === 'client') {
        return clients.some(
            client => client.displayName.trim().toLowerCase() === name
        );
    }
    return false;
}


// ============================================================================
// WEBSOCKET
// ============================================================================

async function connectSocket(existingSocket, authToken, channelId) {
    // Disconnect existing socket if present
    if (existingSocket) {
        if (existingSocket.connected) {
            existingSocket.disconnect();
        }
        existingSocket.removeAllListeners();
    }

    const socket = io(URLS.BASE, {
        auth: {
            token: authToken
        },
        transports: ['polling', 'websocket'],
        reconnection: true,
        reconnectionDelay: 1000,
        reconnectionDelayMax: 5000,
        reconnectionAttempts: 10, // Increased attempts
        timeout: 20000, // Increased timeout
        forceNew: true, // Force new connection
        autoConnect: true
    });

    return new Promise((resolve, reject) => {
        // Connection successful
        socket.on('connect', () => {
            console.log('Current transport:', socket.io.engine.transport.name);
            console.log('[Socket.IO] Connected');
            enableAllUI();
            hideReconnectToast();

            // Subscribe to channel updates
            socket.emit('subscribe', { channelID: channelId });

            // Global pong listener
            socket.off('pong');
            socket.on('pong', (data) => {
                if (data.channelID !== channelId) return;

                console.log('[overlay] Pong received:', data);
                // Only call if function exists (config panel only)
                if (typeof updateOverlayStatus === 'function') {
                    updateOverlayStatus(!!data.online);
                }
            });
        });

        // Connection error
        socket.on('connect_error', (error) => {
            console.error('[Socket.IO] Connection error:', error);
            reject(error);
        });

        // Disconnection handling
        socket.on('disconnect', (reason) => {
            console.warn('[Socket.IO] Disconnected:', reason);
            disableAllUI();

            // If server disconnected us, show reconnect message
            if (reason === 'io server disconnect') {
                // Server forcibly disconnected, manual reconnection needed
                socket.connect();
            }
            // Otherwise Socket.IO will auto-reconnect
        });

        // Reconnection attempt
        socket.io.on('reconnect_attempt', (attemptNumber) => {
            console.log(`[Socket.IO] Reconnection attempt ${attemptNumber}`);
            showReconnectToast(5);
        });

        // Reconnection successful
        socket.on('reconnect', (attemptNumber) => {
            console.log(`[Socket.IO] Reconnected after ${attemptNumber} attempts`);
            enableAllUI();
            hideReconnectToast();

            // Re-subscribe to channel
            socket.emit('subscribe', { channelID: channelId });
        });

        // Reconnection failed
        socket.io.on('reconnect_failed', () => {
            console.error('[Socket.IO] Reconnection failed');
            showError("Connection lost. Please reload the page.");
        });

        // Wait for initial connection
        const timeout = setTimeout(() => {
            reject(new Error('Connection timeout'));
        }, 10000);

        socket.once('connect', () => {
            clearTimeout(timeout);
            resolve(socket);
        });
    });
}

async function pingOverlay(socket, channelId, timeoutMs = 3000) {
    return new Promise(resolve => {
        console.log('[pingOverlay] Starting ping...', {
            connected: socket?.connected,
            channelId
        });

        if (!socket || !socket.connected) {
            console.warn('[pingOverlay] Socket not connected');
            //   updateOverlayStatus(false);
            return resolve(false);
        }

        let responded = false;
        let timeout;

        const onPong = (data) => {
            console.log('[pingOverlay] Received pong:', data);
            console.log('[pingOverlay] data.online value:', data.online); // ADD THIS
            console.log('[pingOverlay] channelID match:', data.channelID === channelId); // ADD THIS

            if (data.channelID === channelId) {
                responded = true;
                cleanup();
                console.log('[pingOverlay] Resolving with:', data.online); // ADD THIS
                //  updateOverlayStatus(data.online);
                resolve(data.online);
            }
        };

        function cleanup() {
            clearTimeout(timeout);
            socket.off('pong', onPong);
        }

        socket.on('pong', onPong);
        socket.emit('ping', { channelID: channelId });
        console.log('[pingOverlay] Ping emitted');

        timeout = setTimeout(() => {
            if (!responded) {
                console.warn('[pingOverlay] Ping timeout - no response received');
                cleanup();
                //  updateOverlayStatus(false);
                resolve(false);
            }
        }, timeoutMs);
    });
}

// ============================================================================
// UI UTILITIES
// ============================================================================

function showLoader(id = "loader") {
    document.getElementById(id)?.classList.remove("hidden");
}

function hideLoader(id = "loader") {
    document.getElementById(id)?.classList.add("hidden");
}

function showModal() {
    document.querySelector('.modal').classList.add('show');
    document.querySelector('.backdrop').classList.add('show');
}

function hideModal() {
    document.querySelector('.modal').classList.remove('show');
    document.querySelector('.backdrop').classList.remove('show');
}

function showError(msg = "An unexpected error occurred.", error = null, elementId = "data-error") {

    hideLoader();

    const el = document.getElementById(elementId);
    if (!el) return;
    el.textContent = msg;
    el.classList.remove("hidden");
    const parent = el.parentElement;
    if (parent) {
        Array.from(parent.children).forEach(child => {
            if (child !== el) child.classList.add('hidden');
        });
    }

    gtag('event', 'error_displayed', {
        event_category: 'UI',
        event_label: msg,
        error_element: elementId,
        error_message: error?.message || 'No error details',
        error_name: error?.name || 'Unknown'
    });
}

function showToast(message, type = 'success', toastId = 'toast', duration = 5000) {
    const toast = document.getElementById(toastId);
    if (!toast) return;

    toast.textContent = '';

    const icon = document.createElement('span');
    icon.className = 'material-symbols-rounded';
    icon.style.marginRight = '8px';

    if (type === 'success') icon.textContent = 'check_circle';
    else if (type === 'error') icon.textContent = 'error';
    else if (type === 'warning') icon.textContent = 'warning';

    toast.appendChild(icon);
    toast.appendChild(document.createTextNode(message));
    toast.classList.add('show');

    setTimeout(() => toast.classList.remove('show'), duration);
}

function showReconnectToast(seconds, toastId = 'toast') {
    const toast = document.getElementById(toastId);
    if (!toast) return;

    toast.textContent = '';

    const icon = document.createElement('span');
    icon.className = 'material-symbols-rounded';
    icon.style.marginRight = '8px';
    icon.textContent = 'sync_problem';

    const text = document.createTextNode(`Connection lost — attempting reconnection`);

    toast.appendChild(icon);
    toast.appendChild(text);
    toast.classList.add('show');
}

function hideReconnectToast(toastId = 'toast') {
    const toast = document.getElementById(toastId);
    if (!toast) return;
    toast.classList.remove('show');
}


function showCardLoader(card) {
    const loader = document.createElement("div");
    loader.className = "card-loader";

    const spinner = document.createElement("div");
    spinner.className = "spinner";

    loader.appendChild(spinner);
    card.appendChild(loader);
}

function hideCardLoader(card) {
    const loader = card.querySelector(".card-loader");
    if (loader) loader.remove();
}

function resolveAssetUrl(url) {
    if (!url) return url;

    if (url.startsWith('http://') || url.startsWith('https://')) {
        try {
            const urlObj = new URL(url);
            if (urlObj.hostname === 'assets.thecozydeck.ch') {
                return url;
            }

            const path = urlObj.pathname;
            return URLS.BASE ? `${URLS.BASE}${path}` : url;
        } catch {
            return url;
        }
    }

    if (url.startsWith('/') && URLS.BASE) {
        return `${URLS.BASE}${url}`;
    }

    return url;
}