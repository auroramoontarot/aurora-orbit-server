function applyPalette(name) {
    const root = document.documentElement;
    const palette = palettes[name];
    if (!palette) return;

    const alias = {
        "--brown-1": "--primary-1",
        "--brown-2": "--primary-2",
        "--brown-3": "--primary-3",
        "--brown-4": "--primary-4",
        "--brown-5": "--primary-5",
        "--brown-6": "--primary-6",
        "--gradient-1": "--gradient-1",
        "--gradient-2": "--gradient-2",
        "--gradient-3": "--gradient-3",
        "--gradient-4": "--gradient-4",
    };

    Object.entries(alias).forEach(([oldVar, newVar]) => {
        root.style.setProperty(oldVar, palette[newVar]);
    });
    return name;
}
// ============================================================================
// API CALLS
// ============================================================================

async function fetchServerConfig(channelId, authToken) {
    try {
        const res = await fetch(`${URLS.BASE}/config/${channelId}`, {
            headers: {
                'Authorization': `Bearer ${authToken}`,
                'Content-Type': 'application/json'
            }
        });
        if (!res.ok) throw new Error(`Server responded ${res.status}`);
        const data = await res.json();
        return data.config || null;
    } catch (err) {
        console.error("Failed to fetch config from server:", err);
        return null;
    }
}


async function saveConfig({
    catalog,
    volume,
    decorList,
    clients,
    hideClients,
    chatMessage,
    auth,
    channelId,
    palette,
    baseUrl = URLS.BASE
}) {

    if (!auth || !channelId) {
        console.error("Auth or channelId missing, cannot save config");
        return;
    }
    const currentWall = decorList.filter(d => d.category === 'Wall')?.[currentWallIndex];
    const currentCounter = decorList.filter(d => d.category === 'Counter')?.[currentCounterIndex];
    const configPayload = {
        catalog: catalog.map(item => {
            const payload = {
                displayName: item.displayName,
                sku: item.sku,
                isDisplayed: item.isDisplayed
            };
            // Only save custom properties if they exist
            if (item.isCustom) {
                payload.isCustom = true;
                if (item.image) payload.image = item.image;
                if (item.category) payload.category = item.category;
            }
            return payload;
        }),
        volume,


        decor: {
            wall: currentWall
                ? {
                    image: currentWall.image,
                    isCustom: !!currentWall.isCustom
                }
                : null,

            counter: currentCounter
                ? {
                    image: currentCounter.image,
                    isCustom: !!currentCounter.isCustom
                }
                : null
        },
        clients: clients.map(c => {
            const payload = {
                displayName: c.displayName,
                isDisplayed: c.isDisplayed
            };

            if (c.isCustom) {
                payload.isCustom = true;
                if (c.image) payload.image = c.image;
                if (c.customId) payload.customId = c.customId;
            }

            return payload;
        }),
        hideClients,
        chatMessage,
        palette
    };

    try {
        const res = await fetch(`${baseUrl}/config/${channelId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${auth.token}`
            },
            body: JSON.stringify(configPayload)
        });

        if (!res.ok) {
            console.error("Failed to save config:", await res.text());
            return false;
        }
        if (window.Twitch?.ext?.send) {
            Twitch.ext.send('broadcast', 'application/json', { type: 'reload' });
        }

        return true;
    } catch (err) {
        console.error("Error saving config:", err);
        return false;
    }
}

