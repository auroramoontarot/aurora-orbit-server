// ============================================================================
// TWITCH FUNCTIONS
// ============================================================================
async function fetchTwitchProducts() {
    if (!Twitch.ext.bits) return [];

    try {
        const products = await Twitch.ext.bits.getProducts();
        products.sort((a, b) => Number(a.cost.amount) - Number(b.cost.amount));
        return products;
    } catch (err) {
        console.error('Failed to fetch Twitch catalog', err);
        showError("Could not load Twitch Bits products. Twitch may be down. Please try again later.");
        return [];
    }
}
