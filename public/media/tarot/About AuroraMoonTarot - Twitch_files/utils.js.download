// ============================================================================
// CONFIGURATION
// ============================================================================
const IS_STAGING = false;

const URLS = {
    CANDIDATES: IS_STAGING
        ? [
            'https://twitch-coffee-server-staging.up.railway.app',
            'https://test.thecozydeck.ch'
        ]
        : [
            'https://cozycafe.thecozydeck.ch',
            'https://test.thecozydeck.ch'
        ],
    BASE: null
};
async function ensureBaseUrl(timeoutMs = 3000) {
    if (URLS.BASE) return URLS.BASE;

    for (const base of URLS.CANDIDATES) {
        try {
            const controller = new AbortController();
            const t = setTimeout(() => controller.abort(), timeoutMs);

            const channelId = currentAuth?.channelId || '61792542'; 
            const testEndpoints = [
                `/config/${channelId}`,
                '/clients',
                `/overlay/?channel=${channelId}`
            ];
            
            const results = await Promise.all(
                testEndpoints.map(endpoint =>
                    fetch(`${base}${endpoint}`, { 
                        signal: controller.signal,
                        headers: currentAuth?.token ? {
                            'Authorization': `Bearer ${currentAuth.token}`
                        } : {}
                    })
                        .then(res => res.ok)
                        .catch(() => false)
                )
            );

            clearTimeout(t);
            const successCount = results.filter(Boolean).length;
            console.log(`[API] ${base} - ${successCount}/3 endpoints succeeded`);
            
            if (successCount == 3) {
                URLS.BASE = base;
                console.log('[API] Using base URL:', base);
                return base;
            }
        } catch (e) {
            console.warn('[API] Base failed:', base, e?.name || e);
        }
    }
    
    const errorMsg = 'Unable to connect to server. Please check your internet connection and try again.';
    showError(errorMsg, new Error('No API base reachable'));
    throw new Error('No API base reachable');
}
